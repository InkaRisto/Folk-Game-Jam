[sub_resource type="GDScript" id="GDScript_fwoee"]
script/source = "enum State {IDLE, CHASE, MELEE, RANGED}
var state = State.IDLE
var player_distance : float

func _physics_process(delta):
	player_distance = global_position.distance_to(Globals.player.global_position)
	match state:
		State.IDLE:
			$AnimatedSprite2D.play(\"idle\")
			if player_distance < 300:
				state = State.CHASE
		State.CHASE:
			$AnimatedSprite2D.play(\"walk\")
			chase_player()
			if player_distance < 80:
				state = State.MELEE
			elif player_distance < 200:
				state = State.RANGED
		State.MELEE:
			melee_attack()
		State.RANGED:
			ranged_attack()
"

